<section class="relative px-10 py-12 overflow-hidden" id="projects">
	<!-- Header -->
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">Our latest projects</p>
	<p class="text-center text-base text-gray-500 mb-8">A selection of recent work</p>

	<!-- Container -->
	<div class="flex flex-wrap justify-center gap-4 max-w-4xl mx-auto mb-8">
		{% for post in collections.project | limit(5) %}
			<!-- Individual entry -->
			<a href="{{ post.url }}" target="_blank" class="flex flex-col gap-2 bg-gray-100 p-5 rounded-xl w-52 border border-transparent transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-gray-100">

				<!-- Tag pill -->
				{% if post.data.tag %}
					<span class="self-start text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 border border-blue-300">
						{{ post.data.tag }}
					</span>
				{% endif %}

				<!-- Title -->
				<p class="text-base font-semibold tracking-tight text-gray-900">
					{{ post.data.title }}
				</p>

				<!-- Description -->
				<p class="text-sm font-normal text-gray-500 leading-relaxed">
					{{ post.data.desc }}
				</p>

				<!-- Status pill -->
				{% if post.data.status == "Completed" %}
					<span class="self-start text-xs font-medium px-2 py-0.5 rounded-full bg-green-200 text-green-700 border border-green-400">Completed</span>
				{% else %}
					<span class="self-start text-xs font-medium px-2 py-0.5 rounded-full bg-yellow-200 text-yellow-700 border border-yellow-400">{{post.data.status}}</span>
				{% endif %}
			</a>
		{% endfor %}
	</div>

	<!-- CTA -->
	<div class="flex justify-center">
		<a href="/projects/"
			class="inline-flex items-center gap-2 text-sm font-medium text-gray-800 border border-gray-300 rounded-lg px-5 py-2.5 transition-all duration-200 hover:border-gray-500">
			View all projects
			<span>→</span>
		</a>
	</div>
</section>
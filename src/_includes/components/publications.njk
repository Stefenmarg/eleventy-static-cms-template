<section class="relative px-10 py-12 overflow-hidden" id="publications">
	<!-- Header -->
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">Our latest publications</p>
	<p class="text-center text-base text-gray-500 mb-8">Recent research and writing from our team</p>

	<!-- Container -->
	<div class="flex flex-wrap justify-center gap-4 max-w-4xl mx-auto mb-8">
		{% for entry in collections.publications | limit(5) %}
			<a href="{{ entry.data.href }}" target="_blank"
				class="flex flex-col gap-2 bg-gray-100 p-5 rounded-xl w-52 border border-transparent transition-all duration-300 hover:-translate-y-1 hover:border-gray-300">

				{% if entry.data.tag %}
					<span class="self-start text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 border border-blue-400 text-blue-700">
						{{ entry.data.tag }}
					</span>
				{% endif %}

				<p class="text-base font-semibold tracking-tight text-gray-900">
					{{ entry.data.name }}
				</p>

				<p class="text-sm font-normal text-gray-500 leading-relaxed">
					{{ entry.data.desc }}
				</p>

				{% if entry.data.date %}
					<div class="flex items-center gap-1.5 mt-auto pt-2">
						<span class="text-xs text-gray-400">{{ entry.data.date | simplifyDate }}</span>
					</div>
				{% endif %}

			</a>
		{% endfor %}
	</div>

	<!-- CTA -->
	<div class="flex justify-center">
		<a href="/publications/"
			class="inline-flex items-center gap-2 text-sm font-medium text-gray-800 border border-gray-300 rounded-lg px-5 py-2.5 transition-all duration-200 hover:border-gray-500">
			View all publications
			<span>→</span>
		</a>
	</div>
</section>
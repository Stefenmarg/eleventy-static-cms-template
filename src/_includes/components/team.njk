<section class="relative px-10 py-12 overflow-hidden" id="team">
	<!-- Header -->
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-6">Our team</p>

	<!-- Container -->
	<div class="flex flex-wrap justify-center gap-8 max-w-4xl mx-auto">
		{% for entry in team.items %}
		  	<!-- Individual entry -->
			<div class="flex flex-col items-center space-y-2 w-40">
				<img src="{{entry.icon}}" alt="{{entry.name}}'s profile picture" class="w-24 h-24 rounded-full object-cover">
				<p class="text-center text-xl font-semibold tracking-tight">{{entry.name}}</p>
				<p class="text-center text-sm font-normal text-gray-500 leading-relaxed">{{entry.desc}}</p>
			</div>
		{% endfor %}
	</div>
</section>